generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  email             String   @unique
  password          String?
  name              String?
  avatar            String?
  role              String   @default("user")
  refreshToken      String?
  oauthProvider     String?
  oauthId           String?
  timezone          String   @default("UTC")
  theme             String   @default("system")
  notificationPrefs String   @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tasks            Task[]
  studySessions    StudySession[]
  productivityLogs ProductivityLog[]
  skills           Skill[]
  schedules        Schedule[]
  focusSessions    FocusSession[]
}

model Task {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String?
  status           String   @default("pending")
  priority         String   @default("medium")
  dueDate          DateTime?
  completedAt      DateTime?
  subject          String?
  tags             String?
  order            Int      @default(0)
  estimatedMinutes Int?
  actualMinutes    Int?

  userId String   @db.ObjectId
  user   User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudySession {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  subject      String
  topic        String?
  startTime    DateTime
  endTime      DateTime?
  duration     Int      @default(0)
  focusScore   Float?
  notes        String?
  productivity Int      @default(0)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model ProductivityLog {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  date             DateTime
  studyHours       Float    @default(0)
  tasksCompleted   Int      @default(0)
  focusScore       Float    @default(0)
  pomodoroSessions Int      @default(0)
  peakHours        String?
  mood             Int?
  notes            String?

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Skill {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  category    String?
  level       Int      @default(1)
  progress    Float    @default(0)
  targetLevel Int?
  notes       String?

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String?
  subject      String
  startDate    DateTime
  endDate      DateTime
  hoursPerDay  Float    @default(0)
  difficulty   String   @default("medium")
  priority     String   @default("medium")
  completed    Boolean  @default(false)
  scheduleData String?
  aiGenerated  Boolean  @default(true)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FocusSession {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String
  duration    Int
  startedAt   DateTime
  endedAt     DateTime?
  completed   Boolean  @default(false)
  interrupted Boolean  @default(false)
  task        String?

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}